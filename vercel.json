{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/index.php?route=index.php"
    },
    {
      "src": "^/(.*\\.php)$",
      "dest": "/api/index.php?route=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.php?route=index.php"
    }
  ]
}
